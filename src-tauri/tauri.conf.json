{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EasyCopy",
  "version": "1.0.1",
  "identifier": "com.easycopy.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "EasyCopy",
        "label": "main",
        "width": 420,
        "height": 520,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "center": false,
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/AppIcon.icns"
    ],
    "category": "Productivity",
    "macOS": {
      "minimumSystemVersion": "10.13"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc2NkZCQ0Q5NTI3MUMwODcKUldTSHdIRlMyYnh2ZGtxYlFIMlJlYkthRk91NlZ1YUpjbDB6S1EwN0JiWm5ZbkZ5MVh3SUpQeGcK",
      "endpoints": [
        "https://github.com/colinfran/easy-copy/releases/latest/download/latest.json"
      ]
    }
  }
}
